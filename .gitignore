# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
**/coverage

# next.js
/.next/
/out/
**/.next/

# production
/build
**/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Turborepo
.turbo

# pnpm (pnpm-lock.yaml est commité intentionnellement pour le CI --frozen-lockfile)
.playwright-mcp

# Captures de travail jetables (preuves d'audit/debug) — isolées, non versionnées
docs/_scratch/

# Lighthouse CI — rapports générés (uploadés en artefact CI, jamais versionnés)
/lh-reports/
.lighthouseci/

# Logs physiques de sync (raw_data des feuilles) — PII membres, jamais versionnés
/sync-logs/
