# ============================================================================
# Vitrine — variables d'environnement
# ============================================================================
# Copier en `.env.local` (gitignoré). Next.js charge les .env* depuis la racine.
#
# NEXT_PUBLIC_BUILD_TIME / NEXT_PUBLIC_BUILD_COMMIT : injectés au build par next.config.ts.

# --- Strapi (blog) ---------------------------------------------------------
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337/api
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Token lecture — LAISSER VIDE en local (rôle Public Strapi). Prod CI : API distante sans token.
NEXT_PUBLIC_STRAPI_API_TOKEN=

# --- Analytics -------------------------------------------------------------
NEXT_PUBLIC_GA_ID_VITRINE=

# --- Formulaires (Google Apps Script) --------------------------------------
NEXT_PUBLIC_CONTACT_FORM_URL=
NEXT_PUBLIC_APP_SCRIPT_URL=

# --- SEO -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://reseauevolvecapital.com
