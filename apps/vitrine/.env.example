# ============================================================================
# Vitrine (apps/vitrine) — variables d'environnement
# ============================================================================
# Next.js charge les fichiers .env* depuis CE dossier (apps/vitrine), PAS depuis
# la racine du monorepo. Copier ce fichier en `.env.local` (gitignoré) et remplir.
#
# NOTE : NEXT_PUBLIC_BUILD_TIME / NEXT_PUBLIC_BUILD_COMMIT ne se définissent PAS ici
#        — ils sont calculés au build par next.config.ts.

# --- Strapi (blog) ---------------------------------------------------------
# API du Strapi local (défaut code si absent : http://localhost:1337/api).
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337/api
# Base pour préfixer les médias relatifs (défaut code si absent : http://localhost:1337).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Token de lecture Strapi — LAISSER VIDE en local : le Strapi local sert le blog via le
# rôle Public (cf. bootstrap dans content/src/index.ts). Un token invalide => 401 sur
# /api/articles. À ne renseigner que pour un Strapi distant protégé par token.
NEXT_PUBLIC_STRAPI_API_TOKEN=

# --- Analytics -------------------------------------------------------------
# Google Analytics 4 — measurement ID vitrine (vide => no-op, aucune erreur).
# Consent Mode v2 : analytics_storage denied par défaut jusqu'au choix utilisateur.
NEXT_PUBLIC_GA_ID_VITRINE=

# --- Formulaires (Google Apps Script) --------------------------------------
# URL Apps Script du formulaire de contact (src/lib/contact.ts).
NEXT_PUBLIC_CONTACT_FORM_URL=
# URL Apps Script de la newsletter (src/lib/newsletter.ts).
NEXT_PUBLIC_APP_SCRIPT_URL=

# --- SEO -------------------------------------------------------------------
# URL publique du site, utilisée pour le partage social (défaut code : https://reseauevolvecapital.com).
NEXT_PUBLIC_SITE_URL=https://reseauevolvecapital.com
