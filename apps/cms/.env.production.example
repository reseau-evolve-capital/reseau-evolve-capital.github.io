# ============================================================================
# apps/cms — Strapi 5 — variables d'environnement de PRODUCTION (droplet DO).
#
# Copier vers /opt/strapi/.env sur le droplet et remplir chaque __CHANGE_ME__.
# Ce fichier est un MODÈLE versionné — n'y mettez JAMAIS de vrai secret.
# ============================================================================

# ---- Serveur / proxy (derrière Traefik) ----
HOST=0.0.0.0
PORT=1337
# URL publique servie par Traefik (TLS terminé par Traefik). Sert aux liens absolus
# de l'admin ET aux URLs de médias (provider local → https://.../uploads/...).
URL=https://strapi.reseauevolvecapital.com
# Indique à Strapi de faire confiance aux en-têtes X-Forwarded-* de Traefik
# (proto/host) pour générer des liens HTTPS corrects. Lu par config/server.ts.
IS_PROXIED=true

# ---- Secrets : générer une valeur FORTE et UNIQUE pour CHACUN ----
# APP_KEYS = 4 valeurs séparées par des virgules. Générer chacune avec :
#   openssl rand -base64 32
APP_KEYS=__CHANGE_ME_1__,__CHANGE_ME_2__,__CHANGE_ME_3__,__CHANGE_ME_4__
API_TOKEN_SALT=__CHANGE_ME__
ADMIN_JWT_SECRET=__CHANGE_ME__
TRANSFER_TOKEN_SALT=__CHANGE_ME__
JWT_SECRET=__CHANGE_ME__

# ---- Base de données (réseau interne → hôte = nom du service `strapi-db`) ----
DATABASE_CLIENT=postgres
DATABASE_HOST=strapi-db
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=__CHANGE_ME_STRONG__
# Réseau privé interne (pas d'Internet) → TLS inutile entre strapi et sa DB.
DATABASE_SSL=false

# ---- CORS : origines autorisées (la vitrine fetch surtout au BUILD, côté serveur,
#      donc CORS est peu critique ; on scope quand même au domaine vitrine). ----
CMS_CORS_ORIGINS=https://reseauevolvecapital.com,https://www.reseauevolvecapital.com

# ---- Traduction auto FR→EN du blog (EDI-008 — plugin strapi-llm-translator) ----
# Clé API OpenAI lue par le plugin. ⚠ Le plugin n'utilise PAS le nom OPENAI_API_KEY.
# Vide = le bouton de traduction renverra une erreur (le reste de Strapi fonctionne).
LLM_TRANSLATOR_LLM_API_KEY=
# Modèle (défaut gpt-4o). Mettre gpt-4o-mini pour réduire le coût.
STRAPI_ADMIN_LLM_TRANSLATOR_LLM_MODEL=
# Endpoint LLM (défaut OpenAI). Laisser vide sauf proxy / Azure OpenAI.
STRAPI_ADMIN_LLM_TRANSLATOR_LLM_BASE_URL=

# ---- Rebuild auto de la vitrine au changement de contenu (repository_dispatch GitHub) ----
# À la publication/dépublication/suppression d'un contenu éditorial, Strapi déclenche le
# workflow deploy-vitrine.yml. NON renseigné = fonctionnalité OFF (no-op).
# Token : PAT fine-grained sur CE dépôt avec permission « Contents: Read and write »
# (ou PAT classic scope `repo`). Server-only — ne JAMAIS exposer au client.
GITHUB_DISPATCH_TOKEN=
# Dépôt cible (défaut ci-dessous si vide) et type d'évènement (doit matcher deploy-vitrine.yml).
GITHUB_DISPATCH_REPO=reseau-evolve-capital/reseau-evolve-capital.github.io
GITHUB_DISPATCH_EVENT_TYPE=strapi-content-update

NODE_ENV=production
