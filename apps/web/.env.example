# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-local>
# URL publique de l'app (origin pour emailRedirectTo)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Upstash (rate-limit magic link) — optionnel en dev (fail-open)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (monitoring — OPS-001). Cf. docs/monitoring/sentry.md.
# VIDE = Sentry DÉSACTIVÉ (no-op) : ni le build ni le runtime ne dépendent de Sentry.
# DSN PUBLIC (clé d'ingestion, pas un secret) — partagé client + serveur.
NEXT_PUBLIC_SENTRY_DSN=
# Environnement remonté à Sentry (ex. production, preview, development). Optionnel.
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Upload des source maps au build — SERVER-ONLY, défini UNIQUEMENT en CI (secret GitHub).
# Absent → withSentryConfig skip l'upload silencieusement (build OK sans token).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Google Analytics 4 (UBA) — flux APP. Cf. docs/analytics/. Measurement ID PUBLIC (pas un secret).
# VIDE = GA DÉSACTIVÉ : <GoogleAnalytics /> rend null, aucun tag chargé.
# ⚠ GA4 pose des cookies → bandeau de consentement OBLIGATOIRE (Consent Mode v2, default denied).
NEXT_PUBLIC_GA_ID_APP=G-GEV5MZ4QPV
# Bandeau de consentement RGPD — variante d'affichage (test des versions).
#   variant : compact (carte ancrée, défaut) | bar (barre basse pleine largeur)
#   side    : gauche (défaut) | droite — ancrage de la variante compact en desktop
NEXT_PUBLIC_CONSENT_BANNER_VARIANT=compact
NEXT_PUBLIC_CONSENT_BANNER_SIDE=gauche

# Web Push (PUSH-001) — clé publique VAPID pour pushManager.subscribe(). PUBLIQUE (pas un secret).
# VIDE = abonnement push désactivé (subscribePush() retourne 'no-vapid-key', aucun crash).
# La clé PRIVÉE (VAPID_PRIVATE_KEY) vit côté Edge Functions UNIQUEMENT, jamais ici.
# Générer la paire : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Expérience A/B « Dashboard V2 » — SERVER-ONLY (résolue côté RSC, jamais shippée au client).
# Force une variante pour tout le monde (kill-switch / dev). v1 | v2 — vide = pas de forçage.
DASHBOARD_V2_FORCE=
# % de membres bucketisés en V2 (0–100, hash déterministe par userId).
# ABSENT ou VIDE = défaut 100 → V2 pour tout le monde (rollout 100 % acté 2026-06-12).
# 0 = kill-switch (retour V1 général) ; valeur intermédiaire (ex. 50) = A/B test.
DASHBOARD_V2_ROLLOUT=

# E2E (Playwright globalSetup) — base locale Supabase
# E2E_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# E2E (Playwright magic-link) : clé service_role/secret locale (cf. `supabase status`)
# SUPABASE_SERVICE_ROLE_KEY=<service-role-ou-sb_secret-local>

# Google Service Account — réseau (NET-006 wizard « Ajouter un club »). SERVER-ONLY.
# Email affiché dans l'encart « Partage d'abord cette feuille en lecture avec : » (étape 2).
# Option 1 (recommandée) : colle directement le client_email du SA (ex. sync@project.iam.gserviceaccount.com).
# Option 2 : si GOOGLE_SA_KEY_BASE64 est défini, client_email est extrait automatiquement → GOOGLE_SA_EMAIL peut rester vide.
# Absent/vide → l'encart affiche « — » et le bouton « Copier » est désactivé (non bloquant).
GOOGLE_SA_EMAIL=

# Price providers (PFT-007) — TOUS optionnels et server-only. Absents → prix null →
# fallback sur le snapshot DB `market_value` (jamais d'écran vide). Cf. docs/PRICE_PROVIDER.md.
# Priorité 1 (recommandé) : Google Apps Script. Mettre le secret en query param dans l'URL.
# GOOGLE_APPS_SCRIPT_URL=
# GOOGLE_APPS_SCRIPT_SECRET=
# Priorité 2 : Google Sheets direct (service account ADC).
# GOOGLE_SHEETS_PRICE_SHEET_ID=
# Priorité 3 (dernier recours, 25 req/jour) : Alpha Vantage.
# ALPHA_VANTAGE_KEY=

# Email transactionnel — Brevo (NTF-001). SERVER-ONLY, jamais exposé au client.
# NON utilisés en local : la stack Supabase CLI capte l'email via Mailpit/Inbucket.
# En prod, injectés côté Supabase (auth.email.smtp) et/ou Edge Functions (API REST).
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
# Clé API v3 Brevo — pour l'envoi via l'API REST depuis les Edge Functions (NTF-002/003/005)
# ET le pipeline newsletter (EDI-006, routes /api/newsletter/*). SERVER-ONLY.
BREVO_API_KEY=

# Newsletter « La Quote-Part » (EDI-006). Toutes SERVER-ONLY sauf NEXT_PUBLIC_*.
# Id numérique de la liste de diffusion membres Brevo (cible de la campagne).
BREVO_MEMBERS_LIST_ID=
# Destinataires de l'envoi de TEST (CSV) — ex. qa@evolve.test,owner@evolve.test
NEWSLETTER_TEST_RECIPIENTS=
# Émetteur de la newsletter (sender Brevo). Le From doit être un domaine vérifié SPF/DKIM.
NEWSLETTER_SENDER_EMAIL=newsletter@reseauevolvecapital.com
NEWSLETTER_SENDER_NAME=Evolve Capital

# CMS Strapi (éditorial) — lecture des newsletters publiées (EDI-006).
# URL de l'API (INCLUT /api). Origine = base d'absolutisation des médias (sans /api).
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337/api
# Token de lecture Strapi (optionnel ; requis si l'API n'est pas publique).
NEXT_PUBLIC_STRAPI_API_TOKEN=
