# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-local>
# URL publique de l'app (origin pour emailRedirectTo)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Upstash (rate-limit magic link) — optionnel en dev (fail-open)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# E2E (Playwright globalSetup) — base locale Supabase
# E2E_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# PROD uniquement (NON utilisés en local — Mailpit gère l'email) :
