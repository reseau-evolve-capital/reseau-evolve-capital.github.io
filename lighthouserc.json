{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter @evolve/web start",
      "startServerReadyPattern": "Ready in|started server on|Local:",
      "startServerReadyTimeout": 60000,
      "url": ["http://localhost:3001/login", "http://localhost:3001/route-inexistante-404"],
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "ignoreStatusCode": true
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*/login$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.8 }],
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        },
        {
          "matchingUrlPattern": ".*/route-inexistante-404$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.8 }],
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": "off"
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lh-reports",
      "reportFilenamePattern": "%%PATHNAME%%-%%DATETIME%%.report.%%EXTENSION%%"
    }
  }
}
