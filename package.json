{
  "name": "evolve-capital",
  "version": "0.1.0",
  "private": true,
  "description": "Evolve Capital — Plateforme d'investissement participatif",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:web": "turbo build --filter=@evolve/web",
    "build:vitrine": "turbo build --filter=@evolve/vitrine",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@evolve/web",
    "dev:vitrine": "turbo dev --filter=@evolve/vitrine",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "storybook": "turbo storybook --filter=@evolve/ui",
    "lighthouse": "lhci autorun",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@lhci/cli": "^0.15.1",
    "@commitlint/config-conventional": "^21.0.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
