{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json", ".prettierrc", "turbo.json"],
  "globalEnv": [
    "NEXT_PUBLIC_GA_ID_APP",
    "NEXT_PUBLIC_GA_ID_VITRINE",
    "NEXT_PUBLIC_CONSENT_BANNER_VARIANT",
    "NEXT_PUBLIC_CONSENT_BANNER_SIDE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "test:e2e": {
      "cache": false
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
